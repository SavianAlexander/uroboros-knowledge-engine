# Set default behavior to automatically normalize line endings
* text=auto

# Explicitly declare text files that should always be LF on check-in
*.py text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yml text eol=lf

# Explicitly declare binary files that should not be touched
*.db binary
*.pdf binary
*.xlsx binary
*.docx binary
*.zip binary
